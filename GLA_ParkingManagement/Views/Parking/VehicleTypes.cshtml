@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Vehicle Types";
}

<div class="page-inner">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-0">
        <div class="page-header-custom mb-3" style="margin-bottom:3rem!important;">
            <span class="bar"></span>
            <h1 class="page-title"> Manage Vehicle Types</h1>
        </div>

        <!-- Add Vehicle Type Button -->
        <button class="btn btn-primary mb-5" onclick="openAddModal()">
            <i class="fa fa-plus"></i> Add Vehicle Type
        </button>
    </div>

    <!-- Card -->
    <div class="card shadow-sm mt-5">
        <div class="card-body">

            <div class="table-responsive">
                <table id="vehicleTypeTable" class="table table-hover table-striped align-middle w-100 ">

                    <thead class="table-primary">
                        <tr>
                            <th>Id</th>
                            <th>Name</th>
                            <th>Hourly Rate</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody></tbody>

                </table>
            </div>

        </div>
    </div>

</div>


<!-- Modal -->
<div class="modal fade" id="addVehicleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-secondary">
                <h5 class="modal-title">Add Vehicle Type</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="vehicleForm">
                    <input type="hidden" id="vehicleId" name="Id" />

                    <div class="mb-3">
                        <label>Name</label>
                        <input type="text" id="vehicleName" name="Name" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Hourly Rate</label>
                        <input type="number" id="hourlyRate" name="HourlyRate" class="form-control" />
                    </div>

                </form>
            </div>

            <div class="modal-footer">
                <button class="btn btn-success" onclick="saveVehicleType()">Save</button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ParkingManage.js"></script>  <!-- External JS -->
}