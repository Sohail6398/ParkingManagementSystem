@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Parking Records";
}

<div class="page-inner">

    <div class="page-header-custom mb-4">
        <span class="bar"></span>
        <h2 class="page-title">Parking Records</h2>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">

            <table id="parkingTable" class="table table-bordered table-hover">

                <thead class="table-primary">
                    <tr>
                        <th>Vehicle</th>
                        <th>Entry Time</th>
                        <th>Exit Time</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>

                <tbody></tbody>

            </table>

        </div>
    </div>

</div>

@section Scripts {
    <script src="~/js/parkingRecords.js"></script>
}