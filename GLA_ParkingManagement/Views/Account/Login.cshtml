@using GLA_ParkingManagement.Domain.DTOs
@model LoginRequest
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
	<link rel="stylesheet" href="css/style.css">
	<link href="~/css/site.css" rel="stylesheet" />
</head>

<body class="auth-bg">

    <div class="container vh-100 d-flex align-items-center justify-content-center">
        <div class="card auth-card shadow">

            <div class="card-body">
                <h3 class="text-center mb-4">Login</h3>

                <form asp-controller="Account" asp-action="Login">

                    <div class="mb-3">
                        <label asp-for="Email">Email</label>
                        <input type="email" id="loginEmail" class="form-control" required asp-for="Email">
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password">Password</label>
                        <input type="password" id="loginPassword" class="form-control" required asp-for="Password" >
                    </div>

                    <div class="mb-3">
                        <input type="checkbox" id="rememberMe" class="form-check-inline" asp-for="RememberMe">
                        <label asp-for="RememberMe">Remember me</label>
                    </div>

                    <button class="btn btn-primary w-100">Login</button>

                    <p class="text-center mt-3">
                        New user? <a href="register.html">Register</a>
                    </p>

                </form>
            </div>
        </div>
    </div>

    <script src="js/auth.js"></script>
</body>
</html>

